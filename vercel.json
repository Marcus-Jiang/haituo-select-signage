{
  "framework": null,
  "buildCommand": null,
  "outputDirectory": ".",
  "cleanUrls": false,
  "trailingSlash": false,
  "routes": [
    { "handle": "filesystem" },
    { "src": "/images/(.*)", "dest": "/images/$1" },
    { "src": "/scenes/(.*)", "dest": "/scenes/$1" },
    { "src": "/details/(.*)", "dest": "/details/$1" },
    { "src": "/js/(.*)", "dest": "/js/$1" },
    { "src": "/css/(.*)", "dest": "/css/$1" },
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/(.*\\.json)", "dest": "/$1" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
